# Postgres local (Docker: docker compose up -d en esta carpeta; puerto host 5434)
DATABASE_URL=postgresql://postgres:1234postgres@localhost:5434/parcial_prog4

# JWT — mínimo 16 caracteres; nunca commitear valor real
SECRET_KEY= cambiar por una clave larga y secreta

# Cloudinary — imagenes de productos (sacar de console.cloudinary.com)
# el API SECRET es sensible: ponelo solo en tu .env local, nunca commitearlo
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Opcional (tienen default en app/core/config.py)
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# BCRYPT_ROUNDS=12
# RATE_LIMIT_AUTH_MAX=5
# RATE_LIMIT_AUTH_WINDOW_MINUTES=15
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174
